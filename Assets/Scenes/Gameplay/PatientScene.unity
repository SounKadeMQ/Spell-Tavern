  m_NavMeshLayer: 0
  m_StaticEditorFlags: 0
  m_IsActive: 1
--- !u!114 &1992937019
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1992937018}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3409004dbbf2ee0438857687469e2f28, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PatientDialogueController
  spellController: {fileID: 1731897578}
  patientWounds: {fileID: 3433762845524071369}
  speakerText: {fileID: 1621598090}
  dialogueText: {fileID: 560711744}
  dialogueRoot: {fileID: 510807623}
  nextButtonRoot: {fileID: 1823204387}
  lines:
  - speaker: Nurse
    text: Okay, lets see here...
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 0
    requiredWoundLocation: 0
  - speaker: Nurse
    text: The patient has 3 external wounds.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 0
    requiredWoundLocation: 0
  - speaker: Nurse
    text: ... It seems like our patient here has a diminishing amount of blood.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 0
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Let's cast Water first to restore some of their blood.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 0
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Press the "D" button to select the Water spell.
    waitForSpellSelect: 1
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 1
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Good! Now, use Left Mouse Click, and follow the symbol of the spell.
    waitForSpellSelect: 0
    waitForSpellCast: 1
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 1
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Great work. That should stabilise our patient's blood levels an amount.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 1
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Now, lets look at these cuts.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 1
    requiredWoundLocation: 0
  - speaker: Nurse
    text: These are small abrasions. We can simply just cast a Fire spell, and cauterise
      them.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 1
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Press the "D" button, to select the Fire spell.
    waitForSpellSelect: 1
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 5
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Make sure you cast the spell ontop of the wounds...
    waitForSpellSelect: 0
    waitForSpellCast: 1
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 5
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Great work. Now cauterise the rest of the external wounds.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 1
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 5
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Good job! All of the external wounds are cleared.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 5
    requiredWoundLocation: 0
  - speaker: Nurse
    text: ... The patient isn't fully stabilised yet...
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 5
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Ah... I see the issue...
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 0
    requiredSpell: 5
    requiredWoundLocation: 0
  - speaker: Nurse
    text: Hang on. Theres a bigger laceration on the patients arm. Lets head towards
      here.
    waitForSpellSelect: 0
    waitForSpellCast: 0
    waitForWoundsCleared: 0
    waitBeforeShowingLine: 0
    transitionToInside: 1
    requiredSpell: 5
    requiredWoundLocation: 0
  characterRevealInterval: 0.1
  audioSource: {fileID: 5268265412323231569}
  voiceTestClip: {fileID: 8300000, guid: 00ce4035e7551f34aa32aa956e3c7733, type: 3}
  outsidePatientRoot: {fileID: 194894041717434413}
  insidePatientRoot: {fileID: 6397697099349844099}
  transitionFadeOverlay: {fileID: 1548773138}
  transitionFadeDuration: 0.35
  transitionMidpointHoldDuration: 0.1
