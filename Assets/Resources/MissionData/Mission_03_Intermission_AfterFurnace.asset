  missionId: ch1_intermission_01
  displayName: "Intermission: Ash in the Ward"
  chapterLabel: Chapter 1
  kind: 1
  patientData: {fileID: 0}
  missionSummary: A story chapter in the tavern clinic after Orren's operation. The team
    realizes the injuries are connected to a cracked ward-stone.
  sceneName: VNScene
  nextMissionId: ch1_surgery_03
  unlockedByDefault: 0
